# OpenAI API Key for GPT-4o-mini analysis
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Paddle Configuration
# Get your credentials from: https://vendors.paddle.com/

# Paddle Vendor ID (found in Paddle Dashboard > Developer Tools > Authentication)
# Format: 12345 or test_12345 for sandbox
NEXT_PUBLIC_PADDLE_VENDOR_ID=your_paddle_vendor_id

# Paddle Price ID for the PricingAudit product ($19)
# Create a product in Paddle Dashboard and copy the Price ID
# Format: pri_01xxxxx
NEXT_PUBLIC_PADDLE_PRICE_ID=your_paddle_price_id

# Paddle Auth Code (for webhook verification - optional for MVP)
# Found in Paddle Dashboard > Developer Tools > Authentication
PADDLE_AUTH_CODE=your_paddle_auth_code
